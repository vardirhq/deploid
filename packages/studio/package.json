{
  "name": "@deploid/studio",
  "version": "2.0.8",
  "description": "Desktop GUI for running Deploid workflows in a project folder",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "deploid-studio": "bin/deploid-studio.cjs"
  },
  "files": [
    "dist/",
    "bin/",
    "renderer/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b && node ./scripts/copy-renderer.mjs",
    "dev": "pnpm build && node ./bin/deploid-studio.cjs",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@deploid/cli": "workspace:*",
    "electron": "^31.7.7"
  },
  "devDependencies": {
    "@types/node": "^24.9.1"
  }
}
