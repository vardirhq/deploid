{
  "name": "@deploid/studio",
  "version": "2.0.8",
  "description": "Desktop GUI for running Deploid workflows in a project folder",
  "author": {
    "name": "MadsenDev",
    "email": "126353638+MadsenDev@users.noreply.github.com"
  },
  "homepage": "https://github.com/vardirhq/deploid",
  "repository": {
    "type": "git",
    "url": "https://github.com/vardirhq/deploid.git"
  },
  "desktopName": "deploid",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b && node ./scripts/copy-renderer.mjs",
    "dev": "pnpm build && electron dist/main.js",
    "dist": "pnpm build && electron-builder --publish never",
    "dist:dir": "pnpm build && electron-builder --dir --publish never",
    "dist:linux": "pnpm build && electron-builder --linux AppImage deb --publish never",
    "dist:mac": "pnpm build && electron-builder --mac dmg zip --publish never",
    "dist:windows": "pnpm build && electron-builder --win nsis portable --publish never"
  },
  "dependencies": {
    "@deploid/cli": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "io.vardir.deploid",
    "productName": "Deploid",
    "executableName": "deploid",
    "icon": "build/icon.png",
    "asar": true,
    "asarUnpack": ["node_modules/**"],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "linux": {
      "category": "Development",
      "maintainer": "MadsenDev <126353638+MadsenDev@users.noreply.github.com>",
      "syncDesktopName": true,
      "synopsis": "Release web applications with Deploid",
      "target": ["AppImage", "deb"]
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    }
  }
}
