{
  "name": "@deploid/cli",
  "version": "2.0.20",
  "description": "Build → package → sign → publish web apps to Android",
  "keywords": [
    "android",
    "capacitor",
    "pwa",
    "mobile",
    "build",
    "publish"
  ],
  "author": "MadsenDev",
  "license": "MIT",
  "homepage": "https://github.com/vardirhq/deploid",
  "repository": {
    "type": "git",
    "url": "https://github.com/vardirhq/deploid.git"
  },
  "bugs": {
    "url": "https://github.com/vardirhq/deploid/issues"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/api.js",
  "bin": {
    "deploid": "bin/deploid"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md"
  ],
  "scripts": {
    "build": "node ./scripts/copy-builtins.mjs && tsc -b",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^8.0.1",
    "googleapis": "^154.1.0",
    "sharp": "^0.33.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@deploid/core": "workspace:*",
    "@deploid/plugin-assets": "workspace:*",
    "@deploid/plugin-artifacts": "workspace:*",
    "@deploid/plugin-build-android": "workspace:*",
    "@deploid/plugin-changelog": "workspace:*",
    "@deploid/plugin-debug-network": "workspace:*",
    "@deploid/plugin-doctor": "workspace:*",
    "@deploid/plugin-deploy-android": "workspace:*",
    "@deploid/plugin-ci-init": "workspace:*",
    "@deploid/plugin-packaging-capacitor": "workspace:*",
    "@deploid/plugin-packaging-electron": "workspace:*",
    "@deploid/plugin-prepare-ios": "workspace:*",
    "@deploid/plugin-publish": "workspace:*",
    "@deploid/plugin-release-init": "workspace:*",
    "@deploid/plugin-version": "workspace:*",
    "@types/node": "^20.19.23",
    "vitest": "^2.1.9"
  },
  "types": "dist/api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#core": {
      "types": "./dist/internal/core/index.d.ts",
      "default": "./dist/internal/core/index.js"
    }
  }
}
